# ===========================================
# INFRASTRUCTURE SETTINGS
# ===========================================

# Elasticsearch settings
ES_LOCAL_VERSION=8.6.2
ES_LOCAL_PORT=9200
ES_LOCAL_CONTAINER_NAME=dust-elasticsearch
ES_LOCAL_HEAP_INIT=512m
ES_LOCAL_HEAP_MAX=512m
ELASTICSEARCH_PASSWORD=changeme

# Kibana settings
KIBANA_LOCAL_PORT=5601
KIBANA_LOCAL_CONTAINER_NAME=dust-kibana
KIBANA_LOCAL_PASSWORD=changemelater
KIBANA_ENCRYPTION_KEY=somethingsomethingsomethingsomething

# ===========================================
# DUST CONFIGURATION
# ===========================================

# Core API settings
NODE_ENV=development
DUST_DEVELOPMENT_SYSTEM_API_KEY=dev-system-api-key
DUST_DEVELOPMENT_WORKSPACE_ID=dev-workspace-id
SESSION_SECRET=local-session-secret
SERVICE_ACCOUNT=dust-dev-service-account
DUST_REGISTRY_SECRET=dev-registry-secret
DUST_CONNECTORS_SECRET=dev-connectors-secret

# Database connections
DATABASE_URL_FRONT=postgres://dev:dev@localhost:5432/dust_front
DATABASE_URL_CORE=postgres://dev:dev@localhost:5432/dust_databases_store
DATABASE_URL_CONNECTORS=postgres://dev:dev@localhost:5432/dust_connectors

# API endpoints
CORE_API=http://localhost:3001
CONNECTORS_API=http://localhost:3002

# ===========================================
# MODEL PROVIDER API KEYS
# ===========================================

# OpenAI API
OPENAI_API_KEY=your-openai-key-here

# Anthropic API
ANTHROPIC_API_KEY=your-anthropic-key-here

# Mistral AI
MISTRAL_API_KEY=your-mistral-key-here

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com

# Google AI Studio (formerly Vertex AI)
GOOGLE_AI_STUDIO_API_KEY=your-google-ai-studio-key-here

# TogetherAI
TOGETHERAI_API_KEY=your-togetherai-key-here

# Deepseek
DEEPSEEK_API_KEY=your-deepseek-key-here

# Fireworks
FIREWORKS_API_KEY=fw_3ZS1ppx6RRjQxeHxmFWf8Yat

# ===========================================
# ADDITIONAL SERVICE KEYS (OPTIONAL)
# ===========================================

# Search-related services
SERP_API_KEY=4a52ccdeac33def7ee63550fc3aa4167622d9aff320244bdf13eb1f0e282d356
BROWSERLESS_API_KEY=S58LQ7LJ6UaJBy745a626e10dab2385f0e531e5a44

# Customer.io for analytics (optional)
CUSTOMERIO_SITE_ID=your-customerio-site-id
CUSTOMERIO_API_KEY=your-customerio-api-key
CUSTOMERIO_ENABLED=false

# ===========================================
# REGIONAL CONFIGURATION (OPTIONAL)
# ===========================================

DUST_REGION=us-central1
DUST_US_URL=https://dust.tt
DUST_EU_URL=https://eu.dust.tt

# ===========================================
# LOGGING AND DEBUGGING
# ===========================================

# Log level for Rust services
RUST_LOG=info

# Hot reloading for front-end development
FAST_REFRESH=true